<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="attributes">
  <div class="resource">
    <label class="resource-label">{{localize "DASU.Item.Roll.Formula"}}</label>
    <span>{{system.formula}}</span>
    <div class="grid grid-4col">
      <div class="grid-span-1">
        <label class="resource-label">{{localize "DASU.Item.Roll.DiceNum"}}</label>
        <input type="text" name="system.roll.diceNum" value="{{system.roll.diceNum}}" data-dtype="Number" />
      </div>
      <div class="grid-span-1">
        <label class="resource-label">{{localize "DASU.Item.Roll.DiceSize"}}</label>
        <input type="text" name="system.roll.diceSize" value="{{system.roll.diceSize}}" data-dtype="String" />
      </div>
      <div class="grid-span-2">
        <label class="resource-label">{{localize "DASU.Item.Roll.DiceBonus"}}</label>
        <input type="text" name="system.roll.diceBonus" value="{{system.roll.diceBonus}}" data-dtype="String" />
      </div>
    </div>
  </div>
</section>
