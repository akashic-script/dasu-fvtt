<div class="resource-popover__row">
  <span class="resource-popover__label resource-popover__label--tactic">{{abbr}}</span>
  <input class="resource-popover__value dasu-pill" value="{{value}}" type="number" min="0" />
</div>
<div class="resource-popover__row resource-popover__stepper">
  <button type="button" class="resource-popover__btn dasu-pill" data-step="-1">−</button>
  <input class="resource-popover__delta dasu-pill" value="1" type="number" min="1" />
  <button type="button" class="resource-popover__btn dasu-pill" data-step="1">+</button>
</div>
