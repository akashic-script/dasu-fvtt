<aside class="sheet-sidebar">

  <div class="sidebar-portrait">
    <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}" />
  </div>

  <div class="sidebar-resources">
    <div class="resource-row" data-action="openResourcePopover" data-resource="health">
      <span class="resource-label resource-label-hp" data-tooltip="{{localize 'DASU.Actor.HP.long'}}">{{localize "DASU.Actor.HP.abbr"}}</span>
      <div class="resource-current">
        <span class="resource-val">{{system.health.value}}</span>
        <span class="resource-sep">/</span>
        <span class="resource-max">{{system.health.max}}</span>
      </div>
      <div class="resource-bar">
        <div class="resource-bar-fill resource-bar-hp" style="width: {{healthPercent}}%"></div>
      </div>
    </div>
    <div class="resource-row" data-action="openResourcePopover" data-resource="power">
      <span class="resource-label resource-label-wp" data-tooltip="{{localize 'DASU.Actor.WP.long'}}">{{localize "DASU.Actor.WP.abbr"}}</span>
      <div class="resource-current">
        <span class="resource-val">{{system.power.value}}</span>
        <span class="resource-sep">/</span>
        <span class="resource-max">{{system.power.max}}</span>
      </div>
      <div class="resource-bar">
        <div class="resource-bar-fill resource-bar-wp" style="width: {{powerPercent}}%"></div>
      </div>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">
      <span class="sidebar-section-title" data-tooltip="{{localize 'DASU.Actor.Section.Attributes'}}">{{localize "DASU.Actor.Section.Attributes"}}</span>
      <span class="sidebar-section-counter" data-tooltip="{{localize 'DASU.Actor.AP.long'}}">{{localize "DASU.Actor.AP.abbr"}}: {{ap.spent}}/{{ap.max}}</span>
    </div>
    <div class="sidebar-attributes">
      {{#each system.attributes as |attribute key|}}
      <div class="attribute-score">
        <span class="attribute-label" data-tooltip="{{attribute.label}}">{{attribute.abbr}}</span>
        <input class="attribute-value dasu-pill rollable" type="text" name="system.attributes.{{key}}.value" value="{{attribute.value}}" data-dtype="Number" data-action="roll" data-roll="@attributes.{{key}}.value" data-label="{{attribute.label}}" />
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- Derived stats --}}
  {{!-- FEAT: Placeholder --}}
  <div class="sidebar-section">
    <div class="sidebar-section-label">
      <span class="sidebar-section-title" data-tooltip="{{localize 'DASU.Actor.Section.Stats'}}">{{localize "DASU.Actor.Section.Stats"}}</span>
    </div>
    <div class="sidebar-stats">
      <div class="stat-score">
        <span class="stat-label" data-tooltip="{{localize 'DASU.Actor.Stat.Avoid.long'}}">{{localize "DASU.Actor.Stat.Avoid.abbr"}}</span>
        <span class="stat-value dasu-pill stat-total">{{system.stats.avoid.value}}</span>
        <label class="stat-bonus-wrap"><span class="stat-bonus-sign">±</span><input class="stat-value dasu-pill stat-bonus" type="text" name="system.stats.avoid.bonus" value="{{system.stats.avoid.bonus}}" data-dtype="Number" /></label>
      </div>
      <div class="stat-score">
        <span class="stat-label" data-tooltip="{{localize 'DASU.Actor.Stat.Defense.long'}}">{{localize "DASU.Actor.Stat.Defense.abbr"}}</span>
        <span class="stat-value dasu-pill stat-total">{{system.stats.defense.value}}</span>
        <label class="stat-bonus-wrap"><span class="stat-bonus-sign">±</span><input class="stat-value dasu-pill stat-bonus" type="text" name="system.stats.defense.bonus" value="{{system.stats.defense.bonus}}" data-dtype="Number" /></label>
      </div>
      <div class="stat-score">
        <span class="stat-label" data-tooltip="{{localize 'DASU.Actor.Stat.Hit.long'}}">{{localize "DASU.Actor.Stat.Hit.abbr"}}</span>
        <span class="stat-value dasu-pill stat-total">{{system.stats.hit.value}}</span>
        <label class="stat-bonus-wrap"><span class="stat-bonus-sign">±</span><input class="stat-value dasu-pill stat-bonus" type="text" name="system.stats.hit.bonus" value="{{system.stats.hit.bonus}}" data-dtype="Number" /></label>
      </div>
      <div class="stat-score">
        <span class="stat-label" data-tooltip="{{localize 'DASU.Actor.Stat.Land.long'}}">{{localize "DASU.Actor.Stat.Land.abbr"}}</span>
        <span class="stat-value dasu-pill stat-total">{{system.stats.land.value}}</span>
        <label class="stat-bonus-wrap"><span class="stat-bonus-sign">±</span><input class="stat-value dasu-pill stat-bonus" type="text" name="system.stats.land.bonus" value="{{system.stats.land.bonus}}" data-dtype="Number" /></label>
      </div>
    </div>
  </div>

  {{!-- Skills --}}
  <div class="sidebar-section">
    <div class="sidebar-section-label">
      <span class="sidebar-section-title" data-tooltip="{{localize 'DASU.Actor.Section.Skills'}}">{{localize "DASU.Actor.Section.Skills"}}</span>
      <span class="sidebar-section-counter" data-tooltip="{{localize 'DASU.Actor.SP.long'}}">{{localize "DASU.Actor.SP.abbr"}}: {{sp.spent}}/{{sp.max}}</span>
    </div>
    <div class="sidebar-skills">
      {{#each system.skills as |skill key|}}
      <div class="skill-row {{#if skill.isCustom}}custom-skill-row{{/if}}" data-skill="{{key}}">
        <span class="skill-label">{{skill.label}}</span>
        <input class="skill-custom-name" type="text" name="system.skills.{{key}}.customName" value="{{skill.customName}}" placeholder="{{skill.label}}" />
        <div class="skill-controls">
          <button type="button" class="skill-btn dasu-pill" data-action="skillStep" data-skill="{{key}}" data-step="-1" {{#unless editable}}disabled{{/unless}}>−</button>
          <input class="skill-value dasu-pill" type="text" name="system.skills.{{key}}.value" value="{{skill.value}}" data-dtype="Number" />
          <button type="button" class="skill-btn dasu-pill" data-action="skillStep" data-skill="{{key}}" data-step="1" {{#unless editable}}disabled{{/unless}}>+</button>
          {{#if skill.isCustom}}<button type="button" class="skill-delete-btn" data-action="deleteCustomSkill" data-id="{{key}}" {{#unless editable}}disabled{{/unless}}><i class="fas fa-trash"></i></button>{{/if}}
        </div>
      </div>
      {{/each}}
      <button type="button" class="skill-add-btn" data-action="createCustomSkill"><i class="fas fa-plus"></i></button>
    </div>
  </div>

</aside>
