<header class="sheet-header">
  <input class="header-name" type="text" name="name" value="{{actor.name}}" placeholder="Character Name" />
  <div class="header-level">
    <span class="header-lv-label">LVL</span>
    <input class="dasu-pill" type="text" name="system.attributes.level.value" value="{{system.attributes.level.value}}" data-dtype="Number" {{#unless editable}}readonly{{/unless}} />
  </div>
</header>
