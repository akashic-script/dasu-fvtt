<header class="sheet-header">
  <div class="actor-header__name-row">
    <h1><input class="actor-header__name" type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'DASU.Actor.SummonerNamePlaceholder'}}" /></h1>
    <button type="button" class="actor-header__init" data-action="rollInit"
            data-tooltip="{{localize 'DASU.Combat.Initiative.Tooltip'}}" aria-label="{{localize 'DASU.Combat.Initiative.Init'}}" {{#unless inCombat}}disabled{{/unless}}>
      <i class="fa-solid fa-angles-right"></i>
    </button>
    <div class="actor-header__level">
      <span class="actor-header__level-label">{{localize "DASU.Actor.Level.long"}}</span>
      <input class="dasu-pill" type="text" name="system.level" value="{{system.level}}" data-dtype="Number" {{#unless editable}}readonly{{/unless}} />
    </div>
  </div>
  <div class="actor-header__identity-row">
    {{#if className}}<span class="actor-header__class-name">{{className}}</span>{{/if}}
    <input class="actor-header__identity" type="text" placeholder="{{localize 'DASU.Actor.ClassPlaceholder'}}" />
    {{#if canAdvance}}
    <button type="button" class="actor-header__levelup" data-action="advance" data-tooltip="{{advanceTooltip}}">
      <i class="fa-solid fa-angles-up"></i>
    </button>
    {{/if}}
    <div class="actor-header__level actor-header__level--merit" data-action="openMeritPopover">
      <span class="actor-header__level-label">{{localize "DASU.Actor.Merit.long"}}</span>
      <input class="dasu-pill" type="text" name="system.merit" value="{{system.merit}}" data-dtype="Number" {{#unless editable}}readonly{{/unless}} />
    </div>
  </div>
  <div class="actor-header__resistances">
    {{#each resistances as |resistance key|}}
    <div class="actor-header__resistance {{resistance.cssClass}}" data-resistance="{{key}}" data-tooltip="{{localize (concat 'DASU.DamageType.' (capitalize key))}}">
      <div class="actor-header__resistance-top" data-action="showResistance" data-resistance="{{key}}">
        <img class="actor-header__resistance-icon" src="systems/dasu/assets/resistances/{{key}}.png" alt="{{key}}" />
        <span class="actor-header__resistance-value">{{resistance.abbr}}</span>
      </div>
      <select class="actor-header__resistance-select" name="system.resistances.{{key}}.base" data-dtype="Number">
        {{selectOptions @root.resistanceLevelOptions selected=resistance.base localize=true}}
      </select>
    </div>
    {{/each}}
  </div>
</header>
