<ol class='items-list'>
  <li class='items-header'>
    <div class='item-name'>{{localize 'Name'}}</div>
    <div class='item-controls'>
      <a
        class='item-control item-create'
        data-action='createItem'
        title='Create item'
        data-type='feature'
      >
        <i class='fas fa-plus'></i>
        {{localize 'DOCUMENT.New' type='feature'}}
      </a>
    </div>
  </li>
  {{#each features as |item id|}}
    <li class='item flexrow' data-item-id='{{item._id}}' data-item-type='feature'>
      <div class='item-name'>
        <div class='item-image'>
          <a class='rollable' data-action='roll' data-roll-type='item'>
            <img src='{{item.img}}' title='{{item.name}}' />
          </a>
        </div>
        <h4>{{item.name}}</h4>
      </div>
      <div class='item-controls'>
        <a class='item-control item-edit' data-action='editItem' title='Edit'>
          <i class='fas fa-edit'></i>
        </a>
        <a class='item-control item-menu' data-action='menuItem' title='More'>
          <i class='fas fa-bars'></i>
        </a>
      </div>
    </li>
  {{/each}}
</ol>
