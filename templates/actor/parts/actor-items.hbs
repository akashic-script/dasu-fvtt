<ol class='items-list'>

  {{!-- Weapons --}}
  <li class='items-header' data-section='weapon'>
    <div class='item-name'>{{localize "TYPES.Item.weapon"}}</div>
    <div class='item-formula'>{{localize "DASU.Item.Weapon.Damage"}}</div>
    <div class='item-formula'>{{localize "DASU.Item.Weapon.ToHit"}}</div>
    <div class='item-controls'>
      <a
        class='item-control item-create'
        data-action='createItem'
        data-tooltip='{{localize "DOCUMENT.Create" type="Weapon"}}'
        data-type='weapon'
      >
        <i class='fas fa-plus'></i>
      </a>
    </div>
  </li>
  {{#each weapons as |item|}}
    <li class='item' data-item-id='{{item._id}}' data-item-type='weapon'>
      <div class='item-name'>
        <div class='item-image'>
          <a class='rollable' data-action='roll' data-roll-type='item'>
            <img src='{{item.img}}' title='{{item.name}}' />
          </a>
        </div>
        <h4>{{item.name}}</h4>
      </div>
      <div class='item-formula'>{{item.system.damage.value}}</div>
      <div class='item-formula'>{{item.system.toHit}}</div>
      <div class='item-controls'>
        <a class='item-control item-edit' data-action='editItem' data-tooltip='{{localize "DASU.Sheet.EditItem"}}'>
          <i class='fas fa-edit'></i>
        </a>
        <a class='item-control item-menu' data-action='menuItem' data-tooltip='{{localize "DASU.Sheet.MoreOptions"}}'>
          <i class='fas fa-bars'></i>
        </a>
      </div>
    </li>
  {{/each}}

  {{!-- Items / Gear --}}
  <li class='items-header' data-section='item'>
    <div class='item-name'>{{localize "TYPES.Item.item"}}</div>
    <div class='item-controls'>
      <a
        class='item-control item-create'
        data-action='createItem'
        data-tooltip='{{localize "DOCUMENT.Create" type="Item"}}'
        data-type='item'
      >
        <i class='fas fa-plus'></i>
      </a>
    </div>
  </li>
  {{#each gear as |item|}}
    <li class='item' data-item-id='{{item._id}}' data-item-type='item'>
      <div class='item-name'>
        <div class='item-image'>
          <a class='rollable' data-action='roll' data-roll-type='item'>
            <img src='{{item.img}}' title='{{item.name}}' />
          </a>
        </div>
        <h4>{{item.name}}</h4>
      </div>
      <div class='item-controls'>
        <a class='item-control item-edit' data-action='editItem' data-tooltip='{{localize "DASU.Sheet.EditItem"}}'>
          <i class='fas fa-edit'></i>
        </a>
        <a class='item-control item-menu' data-action='menuItem' data-tooltip='{{localize "DASU.Sheet.MoreOptions"}}'>
          <i class='fas fa-bars'></i>
        </a>
      </div>
    </li>
  {{/each}}

</ol>
