{{! Sheet Header }}
<header class='sheet-header'>
  <img
    class='profile-img'
    src='{{actor.img}}'
    data-edit='img'
    data-action='onEditImage'
    data-tooltip='{{actor.name}}'
    height='100'
    width='100'
  />
  <div class='header-fields'>
    <div class='document-name'>
      <input
        name='name'
        type='text'
        value='{{actor.name}}'
        placeholder='Name'
      />
    </div>
    {{! The grid classes are defined in scss/global/_grid.scss. To use,
      use both the "grid" and "grid-Ncol" class where "N" can be any number
      from 1 to 12 and will create that number of columns.  }}
    <div class='resources grid grid-3col'>

      {{! "flex-group-center" is also defined in the _grid.scss file
        and it will add a small amount of padding, a border, and will
        center all of its child elements content and text. }}
      <div class='resource flex-group-center'>
        <label for='system.hp.current' class='resource-label'>
          HP
        </label>
        <div class='resource-content flexrow flex-center flex-between'>
          <input
            type='text'
            name='system.hp.current'
            value='{{system.hp.current}}'
            data-dtype='Number'
          />
          <span> / </span>
          <input
            type='text'
            name='system.hp.max'
            value='{{system.hp.max}}'
            data-dtype='Number'
          />
        </div>
      </div>

      <div class='resource flex-group-center'>
        <label for='system.wp.current' class='resource-label'>
          WP
        </label>
        <div class='resource-content flexrow flex-center flex-between'>
          <input
            type='text'
            name='system.wp.current'
            value='{{system.wp.current}}'
            data-dtype='Number'
          />
          <span> / </span>
          <input
            type='text'
            name='system.wp.max'
            value='{{system.wp.max}}'
            data-dtype='Number'
          />
        </div>
      </div>

      <div class='resource flex-group-center'>
        {{#if (or (eq actor.type 'summoner') (eq actor.type 'daemon'))}}
          <label class='resource-label'>
            {{localize 'DASU.Actor.base.FIELDS.level.label'}}
          </label>
          <div class='resource-content flexrow flex-center flex-between'>
            <input
              type='text'
              name='system.level'
              value='{{system.level}}'
              data-dtype='Number'
            />
            {{#if editable}}
              <button type='button' 
                      class='level-up-btn' 
                      data-action='levelUp'
                      data-tooltip='{{localize "DASU.Actor.levelUp.tooltip"}}'>
                <i class='fas fa-arrow-up'></i>
              </button>
            {{/if}}
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</header>