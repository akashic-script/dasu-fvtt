<ol class="combat-tracker plain dasu theme-dark dasu-combat-tracker {{#if isStaging}}dasu-combat-tracker--staging{{/if}} dasu-combat-tracker--{{encounterKind}}">
    {{#if canSetKind}}
    <li class="dasu-encounter-kind" role="group" aria-label="{{ localize "DASU.Combat.Kind.Label" }}">
        {{#each kinds}}
        <button type="button" class="dasu-encounter-kind__option {{#if active}}dasu-encounter-kind__option--active{{/if}}"
                data-action="dasuSetKind" data-kind="{{ key }}" aria-pressed="{{#if active}}true{{else}}false{{/if}}">
            {{ localize label }}
        </button>
        {{/each}}
    </li>
    {{/if}}
    {{#each turns}}
    <li class="combatant dasu-combatant {{ css }}" data-combatant-id="{{ id }}" data-action="activateCombatant">
        <div class="dasu-combatant__main">
            {{!-- Image --}}
            <img class="token-image" src="{{ img }}" alt="{{ name }}" loading="lazy">

            {{!-- Name & Controls --}}
            <div class="token-name">
                <strong class="name">{{ name }}</strong>
                <div class="combatant-controls">
                    {{#if @root.user.isGM}}
                    <button type="button" class="inline-control combatant-control icon fa-solid fa-eye-slash {{#if hidden}}active{{/if}}"
                            data-action="toggleHidden" data-tooltip="{{ localize "COMBAT.ToggleVis" }}" aria-label="{{ localize "COMBAT.ToggleVis" }}"></button>
                    <button type="button" class="inline-control combatant-control icon fa-solid fa-skull {{#if isDefeated}}active{{/if}}"
                            data-action="toggleDefeated" data-tooltip="{{ localize "COMBAT.ToggleDead" }}" aria-label="{{ localize "COMBAT.ToggleDead" }}"></button>
                    {{/if}}
                    {{#if canPing}}
                    <button type="button" class="inline-control combatant-control icon fa-solid fa-bullseye"
                            data-action="pingCombatant" data-tooltip="{{ localize "COMBAT.PingCombatant" }}" aria-label="{{ localize "COMBAT.PingCombatant" }}"></button>
                    {{/if}}
                    {{#unless @root.user.isGM}}
                    <button type="button" class="inline-control combatant-control icon fa-solid fa-arrows-to-eye"
                            data-action="panToCombatant" data-tooltip="{{ localize "COMBAT.PanToCombatant" }}" aria-label="{{ localize "COMBAT.PanToCombatant" }}"></button>
                    {{/unless}}
                    <div class="token-effects" data-tooltip-html="{{ effects.tooltip }}">
                        {{#each effects.icons}}
                        <img class="token-effect" src="{{ img }}" alt="{{ name }}">
                        {{/each}}
                    </div>
                </div>
            </div>

            {{!-- Resource --}}
            {{#if resource includeZero=true}}
            <div class="token-resource">
                <span class="resource">{{ resource }}</span>
            </div>
            {{/if}}

            {{!-- Initiative --}}
            <div class="token-initiative">
                {{#if initiative includeZero=true}}
                {{#if @root.hasDecimals}}
                <span>{{ initiative }}</span>
                {{else}}
                <input type="text" class="initiative-input" inputmode="numeric" pattern="^[+=\-]?\d*" value="{{initiative}}"
                       aria-label="{{localize "COMBAT.InitiativeScore"}}" {{#unless @root.user.isGM}}readonly{{/unless}}>
                {{/if}}
                {{else if isOwner}}
                <button type="button" class="combatant-control roll" data-action="rollInitiative"
                        data-tooltip="{{ localize "COMBAT.InitiativeRoll" }}"
                        aria-label="{{ localize "COMBAT.InitiativeRoll" }}"
                        style="--initiative-icon: url('{{ @root.initiativeIcon.icon }}'); --initiative-icon-hover: url('{{ @root.initiativeIcon.hover }}');"></button>
                {{/if}}
            </div>
        </div>

        {{!-- DASU: action pips for non-summoner combatants --}}
        {{#unless dasu.isSummoner}}
        {{#if dasu.actions}}
        {{#unless @root.isStaging}}
        <div class="dasu-meta">
            {{> "systems/dasu/templates/combat/parts/actions.hbs" dasu.actions}}
        </div>
        {{/unless}}
        {{/if}}
        {{/unless}}

        {{!-- DASU: summoner fielding tree --}}
        {{#if dasu.isSummoner}}
        <div class="dasu-team dasu-team--framed">
            <span class="dasu-team__legend">{{ localize "DASU.Combat.Field.Team" }}</span>

            {{!-- Action pips (left) + strain (right) --}}
            <div class="dasu-team__header dasu-meta">
                {{#if dasu.actions}}
                {{#unless @root.isStaging}}
                {{> "systems/dasu/templates/combat/parts/actions.hbs" dasu.actions}}
                {{/unless}}
                {{/if}}
                <span class="dasu-strain {{#if dasu.strain.over}}dasu-strain--over{{/if}}"
                      data-tooltip="{{ localize "DASU.Combat.Strain.Tooltip" }}">
                    <i class="fa-solid fa-brain"></i>
                    {{ dasu.strain.used }} / {{ dasu.strain.cap }}
                </span>
            </div>

            {{!-- Fielded team --}}
            {{#if dasu.hasFielded}}
            <ul class="dasu-team__tree">
                {{#each dasu.fielded}}
                {{> "systems/dasu/templates/combat/parts/daemon-row.hbs" this staging=true}}
                {{/each}}
            </ul>
            {{/if}}

            {{!-- Bench: unfielded stock --}}
            {{#if dasu.benchCount}}
            <button type="button" class="dasu-team__bench-toggle" data-action="dasuToggleBench"
                    aria-expanded="{{#unless dasu.collapsed}}true{{else}}false{{/unless}}">
                <i class="fa-solid fa-angle-{{#if dasu.collapsed}}right{{else}}down{{/if}}"></i>
                {{ localize "DASU.Combat.Field.Bench" }} ({{ dasu.benchCount }})
            </button>
            {{#unless dasu.collapsed}}
            <ul class="dasu-team__tree dasu-team__tree--bench">
                {{#each dasu.bench}}
                {{> "systems/dasu/templates/combat/parts/daemon-row.hbs" this staging=true}}
                {{/each}}
            </ul>
            {{/unless}}
            {{/if}}

            {{!-- Empty stock --}}
            {{#unless dasu.hasFielded}}
            {{#unless dasu.benchCount}}
            {{#if @root.isStaging}}
            <div class="dasu-team__empty">{{ localize "DASU.Combat.Field.Empty" }}</div>
            {{/if}}
            {{/unless}}
            {{/unless}}
        </div>
        {{/if}}
    </li>
    {{/each}}
</ol>
